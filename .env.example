# ---------------------------------------------------------------------------
# Business OS — Environment Variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# Public site URL (used for SEO canonical URLs, Open Graph, auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API
# Safe to expose to the browser (protected by Row Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secret. NEVER expose to the client. Bypasses RLS — use with care.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Local Supabase CLI only (referenced by supabase/config.toml). Not used by the
# Next.js app. For a cloud project, configure Google OAuth in the dashboard.
# ---------------------------------------------------------------------------
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id
SUPABASE_AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
