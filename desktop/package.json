{
  "name": "business-os-desktop",
  "version": "1.2.0",
  "private": true,
  "description": "Business OS desktop app",
  "author": "Business OS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "app.businessos.desktop",
    "productName": "Business OS",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Business OS"
    }
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
